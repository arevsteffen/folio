<script>
  (function () {
    var companies = {
      'Hogarth': 'https://www.linkedin.com/company/hogarth/',
      'Avenue Code': 'https://avenuecode.com/en/home/',
      'Warren': 'https://warren.com.br/',
      'Xprog': 'https://xprog.com.br/'
    };

    function applyRollingEffect(a, p) {
      var lineHeight = parseFloat(getComputedStyle(p).lineHeight) || 20;
      var text = a.getAttribute('data-company-text');

      var container = document.createElement('span');
      container.style.cssText = 'display:inline-flex;overflow:hidden;vertical-align:top;text-shadow:0 ' + lineHeight + 'px 0 currentColor;';

      text.split('').forEach(function (char, i) {
        var span = document.createElement('span');
        span.textContent = char === ' ' ? ' ' : char;
        span.style.cssText = 'display:block;white-space:pre;line-height:' + lineHeight + 'px;transition:transform 0.4s cubic-bezier(0.19,1,0.22,1);transition-delay:' + (i * 20) + 'ms;';
        container.appendChild(span);
      });

      a.innerHTML = '';
      a.appendChild(container);

      a.addEventListener('mouseenter', function () {
        container.querySelectorAll('span').forEach(function (span, i) {
          span.style.transitionDelay = (i * 20) + 'ms';
          span.style.transform = 'translateY(-' + lineHeight + 'px)';
        });
      });
      a.addEventListener('mouseleave', function () {
        container.querySelectorAll('span').forEach(function (span, i) {
          span.style.transitionDelay = (i * 20) + 'ms';
          span.style.transform = 'translateY(0)';
        });
      });
    }

    function addLinks() {
      document.querySelectorAll('p.framer-text').forEach(function (p) {
        var text = p.textContent.trim();
        if (companies[text] && !p.querySelector('a')) {
          var a = document.createElement('a');
          a.href = companies[text];
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
          a.setAttribute('data-company-text', text);
          a.style.cssText = 'color:inherit;text-decoration:none;cursor:pointer;display:inline-block;';
          p.textContent = '';
          p.appendChild(a);
          applyRollingEffect(a, p);
        }
      });
    }

    var observer = new MutationObserver(addLinks);
    observer.observe(document.documentElement, { childList: true, subtree: true });
    setTimeout(function () { observer.disconnect(); }, 10000);
  })();
</script>

<script>
(function () {
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (!entry.isIntersecting) return;
      var items = entry.target.querySelectorAll('.framer-032Ue.framer-g2q9aj');
      items.forEach(function (item, i) {
        setTimeout(function () {
          item.classList.add('in-view');
        }, i * 130);
      });
      io.unobserve(entry.target);
    });
  }, { threshold: 0.15 });

  function init() {
    document.querySelectorAll('.framer-evObk').forEach(function (container) {
      container.querySelectorAll('.framer-032Ue.framer-g2q9aj').forEach(function (item) {
        item.classList.add('skill-item-appear');
      });
      io.observe(container);
    });
  }

  // Wait for Framer hydration then init, don't re-run
  var done = false;
  var mo = new MutationObserver(function () {
    if (done) return;
    if (document.querySelector('.framer-evObk .framer-032Ue.framer-g2q9aj')) {
      done = true;
      mo.disconnect();
      init();
    }
  });
  mo.observe(document.documentElement, { childList: true, subtree: true });
  setTimeout(function () { mo.disconnect(); }, 8000);
})();
</script>


